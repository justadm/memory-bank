APP_ENV=production
HOST_API_PORT=18120

POSTGRES_DB=memlayer
POSTGRES_USER=memlayer
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+psycopg://memlayer:change_me_strong_password@db:5432/memlayer

AUTH_ENABLED=true
# Format:
# AUTH_API_KEYS=reader-key:read,agent-write-key:read|write|import,ops-admin-key:read|write|import|admin
AUTH_API_KEYS=agent-write-key:read|write|import,ops-admin-key:read|write|import|admin

MEMORYBANK_URL=https://api.memlayer.ru
AUTO_LINK_ON_CREATE=false
AUTO_LINK_MIN_SIMILARITY=0.35
AUTO_LINK_SEARCH_LIMIT=20
AUTO_LINK_MAX_LINKS=5

# Optional nginx-level second auth layer for adm.memlayer.ru:
# MEMLAYER_ADM_BASIC_AUTH_USER=opsadmin
