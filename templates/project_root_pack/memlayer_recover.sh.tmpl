#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_PATH="${SCRIPT_DIR}/.env.memlayer"

if [[ -f "${ENV_PATH}" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "${ENV_PATH}"
  set +a
fi

RUNTIME_ROOT="${MEMLAYER_RUNTIME_ROOT:-/Users/just/apps/memory.bank}"
DOCKER_BIN="${MEMLAYER_DOCKER_BIN:-/usr/local/bin/docker}"
RECOVER_MODE="${MEMLAYER_RECOVER_MODE:-up}"
WAIT_SECONDS="${MEMLAYER_RECOVER_WAIT_SECONDS:-2}"
HEALTH_TIMEOUT="${MEMLAYER_RECOVER_HEALTH_TIMEOUT_SECONDS:-30}"

if [[ ! -d "${RUNTIME_ROOT}" ]]; then
  echo "memlayer_recover.sh: runtime root does not exist: ${RUNTIME_ROOT}" >&2
  exit 1
fi

if [[ ! -x "${DOCKER_BIN}" ]]; then
  echo "memlayer_recover.sh: docker binary is not executable: ${DOCKER_BIN}" >&2
  exit 1
fi

echo "memlayer_recover.sh: recovering MemLayer runtime in ${RUNTIME_ROOT} using mode=${RECOVER_MODE}"
(
  cd "${RUNTIME_ROOT}"
  if [[ "${RECOVER_MODE}" == "restart-api" ]]; then
    "${DOCKER_BIN}" compose restart api
  else
    "${DOCKER_BIN}" compose up -d
  fi
)

echo "memlayer_recover.sh: waiting for API health"
sleep "${WAIT_SECONDS}"

deadline=$((SECONDS + HEALTH_TIMEOUT))
while (( SECONDS <= deadline )); do
  if "${SCRIPT_DIR}/memlayer_api.sh" GET /health >/dev/null 2>&1; then
    echo "memlayer_recover.sh: MemLayer health restored"
    "${SCRIPT_DIR}/memlayer_api.sh" GET /health
    exit 0
  fi
  sleep 1
done

echo "memlayer_recover.sh: MemLayer health did not recover within ${HEALTH_TIMEOUT}s" >&2
exit 1
