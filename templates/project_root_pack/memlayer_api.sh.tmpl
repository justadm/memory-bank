#!/usr/bin/env bash
set -euo pipefail

COMMAND="${1:-GET}"
PATH_PART="${2:-/health}"
BODY="${3:-}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_PATH="${SCRIPT_DIR}/memlayer.config.json"
ENV_PATH="${SCRIPT_DIR}/.env.memlayer"
EXPLICIT_MEMLAYER_API_URL="${MEMLAYER_API_URL-__UNSET__}"
EXPLICIT_MEMLAYER_EXTRA_URLS="${MEMLAYER_EXTRA_URLS-__UNSET__}"
EXPLICIT_MEMLAYER_RETRY_ATTEMPTS="${MEMLAYER_RETRY_ATTEMPTS-__UNSET__}"
EXPLICIT_MEMLAYER_API_RETRY_ATTEMPTS_OVERRIDE="${MEMLAYER_API_RETRY_ATTEMPTS_OVERRIDE-__UNSET__}"
EXPLICIT_MEMLAYER_CURL_TIMEOUT_SECONDS="${MEMLAYER_CURL_TIMEOUT_SECONDS-__UNSET__}"
EXPLICIT_MEMORYBANK_API_KEY="${MEMORYBANK_API_KEY-__UNSET__}"

if [[ ! -f "${CONFIG_PATH}" ]]; then
  echo "memlayer_api.sh: missing ${CONFIG_PATH}" >&2
  exit 1
fi

if [[ -f "${ENV_PATH}" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "${ENV_PATH}"
  set +a
fi

if [[ "${EXPLICIT_MEMLAYER_API_URL}" != "__UNSET__" ]]; then
  MEMLAYER_API_URL="${EXPLICIT_MEMLAYER_API_URL}"
fi
if [[ "${EXPLICIT_MEMLAYER_EXTRA_URLS}" != "__UNSET__" ]]; then
  MEMLAYER_EXTRA_URLS="${EXPLICIT_MEMLAYER_EXTRA_URLS}"
fi
if [[ "${EXPLICIT_MEMLAYER_RETRY_ATTEMPTS}" != "__UNSET__" ]]; then
  MEMLAYER_RETRY_ATTEMPTS="${EXPLICIT_MEMLAYER_RETRY_ATTEMPTS}"
fi
if [[ "${EXPLICIT_MEMLAYER_API_RETRY_ATTEMPTS_OVERRIDE}" != "__UNSET__" ]]; then
  MEMLAYER_API_RETRY_ATTEMPTS_OVERRIDE="${EXPLICIT_MEMLAYER_API_RETRY_ATTEMPTS_OVERRIDE}"
fi
if [[ "${EXPLICIT_MEMLAYER_CURL_TIMEOUT_SECONDS}" != "__UNSET__" ]]; then
  MEMLAYER_CURL_TIMEOUT_SECONDS="${EXPLICIT_MEMLAYER_CURL_TIMEOUT_SECONDS}"
fi
if [[ "${EXPLICIT_MEMORYBANK_API_KEY}" != "__UNSET__" ]]; then
  MEMORYBANK_API_KEY="${EXPLICIT_MEMORYBANK_API_KEY}"
fi

read_config_value() {
  local key="$1"
  python3 - "$CONFIG_PATH" "$key" <<'PY'
import json
import sys

config_path, key = sys.argv[1], sys.argv[2]
with open(config_path, "r", encoding="utf-8") as fh:
    data = json.load(fh)
value = data.get(key, "")
print(value if value is not None else "")
PY
}

build_url() {
  local base_url="$1"
  local path_part="$2"
  local normalized_base="${base_url%/}"
  local normalized_path="/${path_part#/}"
  printf '%s%s' "${normalized_base}" "${normalized_path}"
}

append_unique() {
  local candidate="$1"
  if [[ -z "${candidate}" ]]; then
    return 0
  fi
  for existing in "${ENDPOINTS[@]:-}"; do
    if [[ "${existing}" == "${candidate}" ]]; then
      return 0
    fi
  done
  ENDPOINTS+=("${candidate}")
}

append_csv_values() {
  local csv="$1"
  if [[ -z "${csv}" ]]; then
    return 0
  fi
  python3 - "$csv" <<'PY' | while IFS= read -r line; do
import sys

for raw in sys.argv[1].split(","):
    value = raw.strip()
    if value:
        print(value)
PY
    append_unique "${line}"
  done
}

compute_backoff_seconds() {
  local attempt="$1"
  case "${attempt}" in
    1) printf '0.5' ;;
    2) printf '1' ;;
    3) printf '2' ;;
    4) printf '3' ;;
    *) printf '5' ;;
  esac
}

run_request_once() {
  local base_url="$1"
  local method="$2"
  local path_part="$3"
  local body="$4"
  local url
  url="$(build_url "${base_url}" "${path_part}")"
  local -a args
  args=(-sS --max-time "${MEMLAYER_CURL_TIMEOUT_SECONDS:-8}" -X "${method}" "${url}")
  if [[ -n "${MEMORYBANK_API_KEY:-}" ]]; then
    args+=(-H "Authorization: Bearer ${MEMORYBANK_API_KEY}")
  fi
  if [[ -n "${body}" ]]; then
    args+=(-H "Content-Type: application/json" --data "${body}")
  fi
  curl "${args[@]}"
}

health_check_endpoint() {
  local base_url="$1"
  run_request_once "${base_url}" "GET" "/health" "" >/dev/null 2>&1
}

resolve_endpoints() {
  local preferred_url
  local fallback_url
  local host_fallback_url
  preferred_url="$(read_config_value preferred_url)"
  fallback_url="$(read_config_value local_fallback_url)"
  host_fallback_url="$(read_config_value human_preferred_url)"

  ENDPOINTS=()
  append_unique "${MEMLAYER_API_URL:-}"
  append_unique "${preferred_url}"
  append_unique "http://host.docker.internal:18100"
  append_unique "http://127.0.0.1:18100"
  append_unique "http://api:8000"
  append_unique "http://memorybank-api-1:8000"
  append_unique "${fallback_url}"
  append_unique "${host_fallback_url}"
  append_csv_values "${MEMLAYER_EXTRA_URLS:-}"
}

select_working_endpoint() {
  local retry_attempts="${MEMLAYER_API_RETRY_ATTEMPTS_OVERRIDE:-${MEMLAYER_RETRY_ATTEMPTS:-2}}"
  local endpoint
  local attempt

  if [[ ! "${retry_attempts}" =~ ^[0-9]+$ ]] || [[ "${retry_attempts}" -lt 1 ]]; then
    retry_attempts=2
  fi

  for endpoint in "${ENDPOINTS[@]}"; do
    for (( attempt=1; attempt<=retry_attempts; attempt++ )); do
      if health_check_endpoint "${endpoint}"; then
        printf '%s' "${endpoint}"
        return 0
      fi
      if [[ "${attempt}" -lt "${retry_attempts}" ]]; then
        local backoff
        backoff="$(compute_backoff_seconds "${attempt}")"
        echo "memlayer_api.sh: endpoint ${endpoint} health attempt ${attempt}/${retry_attempts} failed, retrying in ${backoff}s" >&2
        sleep "${backoff}"
      fi
    done
    echo "memlayer_api.sh: endpoint ${endpoint} is unavailable, trying next candidate" >&2
  done

  return 1
}

dns_report() {
  local base_url="$1"
  python3 - "$base_url" <<'PY'
from urllib.parse import urlparse
import socket
import sys

host = urlparse(sys.argv[1]).hostname or ""
if not host:
    print("dns: n/a")
    raise SystemExit(0)
try:
    infos = socket.getaddrinfo(host, None)
except Exception as exc:
    print(f"dns: fail ({exc})")
    raise SystemExit(0)

addrs = []
for info in infos:
    addr = info[4][0]
    if addr not in addrs:
        addrs.append(addr)
print("dns: ok -> " + ", ".join(addrs))
PY
}

doctor() {
  resolve_endpoints
  echo "memlayer_api.sh doctor"
  echo "config_path=${CONFIG_PATH}"
  echo "env_path=${ENV_PATH}"
  echo "memlayer_api_url=${MEMLAYER_API_URL:-}"
  echo "memlayer_extra_urls=${MEMLAYER_EXTRA_URLS:-}"
  echo "retry_attempts=${MEMLAYER_RETRY_ATTEMPTS:-2}"
  echo "curl_timeout=${MEMLAYER_CURL_TIMEOUT_SECONDS:-8}"
  echo "memorybank_api_key_configured=$([[ -n "${MEMORYBANK_API_KEY:-}" ]] && echo yes || echo no)"
  echo
  echo "endpoint_candidates:"
  for endpoint in "${ENDPOINTS[@]}"; do
    echo "- ${endpoint}"
    dns_report "${endpoint}" | sed 's/^/  /'
    if health_check_endpoint "${endpoint}"; then
      echo "  health: ok"
    else
      echo "  health: fail"
    fi
  done
  if command -v "${MEMLAYER_DOCKER_BIN:-/usr/local/bin/docker}" >/dev/null 2>&1; then
    echo
    echo "docker_status:"
    "${MEMLAYER_DOCKER_BIN:-/usr/local/bin/docker}" compose -f /Users/just/apps/memory.bank/docker-compose.yml ps 2>/dev/null || true
  fi
}

if [[ "${COMMAND}" == "doctor" ]]; then
  doctor
  exit 0
fi

resolve_endpoints
SELECTED_ENDPOINT="$(select_working_endpoint)" || {
  echo "memlayer_api.sh: no reachable MemLayer endpoint found" >&2
  exit 1
}

run_request_once "${SELECTED_ENDPOINT}" "${COMMAND}" "${PATH_PART}" "${BODY}"
