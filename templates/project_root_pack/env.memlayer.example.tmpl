MEMORYBANK_URL={preferred_url}
MEMORYBANK_FALLBACK_URL={local_url}
MEMORYBANK_HUMAN_URL={human_url}
MEMORYBANK_PROJECT_NAME={project_name}
MEMORYBANK_PROJECT_ROOT={project_root}
MEMORYBANK_EXISTING_ENTRY_MODE=update
MEMORYBANK_API_KEY=
MEMLAYER_API_URL={preferred_url}
MEMLAYER_EXTRA_URLS=http://host.docker.internal:18100,http://127.0.0.1:18100,http://api:8000,http://memorybank-api-1:8000,https://memlayer.loc/api
# Production:
# MEMLAYER_API_URL=https://api.memlayer.ru
# Host machine fallback:
# MEMLAYER_API_URL=http://127.0.0.1:18100
# Docker container talking to host:
# MEMLAYER_API_URL=http://host.docker.internal:18100
# Same docker-compose network:
# MEMLAYER_API_URL=http://api:8000
# Explicit container name:
# MEMLAYER_API_URL=http://memorybank-api-1:8000
# Browser/nginx path:
# MEMLAYER_API_URL=https://memlayer.loc/api
MEMLAYER_RETRY_ATTEMPTS=2
MEMLAYER_WRITE_RETRY_ATTEMPTS=1
MEMLAYER_WATCHDOG_QUERY=architecture
MEMLAYER_WATCHDOG_LIMIT=5
MEMLAYER_WATCHDOG_AUTO_RECOVER=false
MEMLAYER_RUNTIME_ROOT=/Users/just/apps/memory.bank
MEMLAYER_DOCKER_BIN=/usr/local/bin/docker
MEMLAYER_RECOVER_MODE=up
MEMLAYER_RECOVER_WAIT_SECONDS=2
MEMLAYER_RECOVER_HEALTH_TIMEOUT_SECONDS=30
MEMLAYER_LAUNCHD_LABEL=loc.memlayer.runtime
MEMLAYER_LAUNCHD_START_INTERVAL_SECONDS=300
MEMLAYER_SNAPSHOT_QUERY=
MEMLAYER_SNAPSHOT_LIMIT=12
