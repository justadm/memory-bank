{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memlayer.ru/schemas/revision_pass.v0.schema.json",
  "title": "MemLayer Revision Pass v0",
  "description": "Pre-action revision contract for risky agent work before production writes, data mutation, deploys, reimports, or cleanup.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact",
    "mode",
    "task",
    "started_at",
    "state_sync",
    "roles_required",
    "roles_completed",
    "findings",
    "go_no_go",
    "privacy"
  ],
  "properties": {
    "schema_version": {
      "const": "revision_pass.v0"
    },
    "artifact": {
      "const": "local.agent.revision_pass_before_production_write.v0"
    },
    "mode": {
      "type": "string",
      "enum": [
        "lite",
        "standard",
        "full"
      ]
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "project",
        "risk_level"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 8
        },
        "project": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": [
            "string",
            "null"
          ]
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "state_sync": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_status_checked",
        "local_head",
        "runtime_source_version",
        "runtime_import_path",
        "latest_handoff_checked",
        "feature_flags_checked",
        "health_checked"
      ],
      "properties": {
        "git_status_checked": {
          "type": "boolean"
        },
        "local_head": {
          "type": [
            "string",
            "null"
          ]
        },
        "runtime_source_version": {
          "type": [
            "string",
            "null"
          ],
          "description": "Production HEAD, deployed image tag, source path version, or equivalent observed runtime version."
        },
        "runtime_import_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "latest_handoff_checked": {
          "type": "boolean"
        },
        "feature_flags_checked": {
          "type": "boolean"
        },
        "health_checked": {
          "type": "boolean"
        },
        "health_summary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "roles_required": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "historian",
          "diff_reviewer",
          "runtime_verifier",
          "risk_owner",
          "release_operator"
        ]
      }
    },
    "roles_completed": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "historian",
          "diff_reviewer",
          "runtime_verifier",
          "risk_owner",
          "release_operator"
        ]
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "severity",
          "claim",
          "evidence",
          "confidence",
          "blocks_go"
        ],
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 3
          },
          "severity": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "claim": {
            "type": "string",
            "minLength": 8
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "unknowns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocks_go": {
            "type": "boolean"
          }
        }
      }
    },
    "go_no_go": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "decided_by",
        "proven_facts",
        "unknowns",
        "allowed_changes",
        "forbidden_changes",
        "required_verification",
        "rollback",
        "evidence_log_target"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "GO",
            "NO-GO",
            "EMERGENCY-ROLLBACK"
          ]
        },
        "decided_by": {
          "type": "string",
          "minLength": 1
        },
        "proven_facts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unknowns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_changes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_changes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "rollback": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_log_target": {
          "type": [
            "string",
            "null"
          ],
          "description": "MemLayer project, local file, or both. Must not include credentials."
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contains_secrets",
        "contains_customer_data",
        "redaction_applied",
        "raw_payloads_included"
      ],
      "properties": {
        "contains_secrets": {
          "type": "boolean"
        },
        "contains_customer_data": {
          "type": "boolean"
        },
        "redaction_applied": {
          "type": "boolean"
        },
        "raw_payloads_included": {
          "type": "boolean"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
