{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memlayer.ru/schemas/post_action_evidence.v0.schema.json",
  "title": "MemLayer Post-Action Evidence v0",
  "description": "Post-action evidence contract for deploys, reimports, cleanup, data writes, and other risky agent actions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "action_type",
    "approved_by",
    "approved_in_current_thread",
    "acted_at",
    "target",
    "source_version",
    "changes",
    "commands",
    "health_smoke",
    "read_back",
    "not_changed",
    "residual_risks",
    "evidence_written_to",
    "privacy_check"
  ],
  "properties": {
    "schema_version": {
      "const": "post_action_evidence.v0"
    },
    "action_type": {
      "type": "string",
      "enum": [
        "deploy",
        "rollback",
        "cleanup",
        "reimport",
        "crm_write",
        "flag_change",
        "data_write",
        "smoke_only"
      ]
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "approved_in_current_thread": {
      "type": "boolean",
      "description": "Must be true for production writes, deploys, reimports, cleanup, or customer-data mutation."
    },
    "acted_at": {
      "type": "string",
      "format": "date-time"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "project",
        "environment"
      ],
      "properties": {
        "system": {
          "type": "string",
          "minLength": 1
        },
        "project": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "enum": [
            "local",
            "staging",
            "production"
          ]
        },
        "runtime_path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "source_version": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "before",
        "after"
      ],
      "properties": {
        "before": {
          "type": [
            "string",
            "null"
          ]
        },
        "after": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "status",
          "redacted"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 2
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "skipped"
            ]
          },
          "redacted": {
            "type": "boolean"
          },
          "summary": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "health_smoke": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check",
          "status"
        ],
        "properties": {
          "check": {
            "type": "string",
            "minLength": 2
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "skipped"
            ]
          },
          "evidence": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "read_back": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim",
          "evidence"
        ],
        "properties": {
          "claim": {
            "type": "string",
            "minLength": 3
          },
          "evidence": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "not_changed": {
      "type": "array",
      "description": "Explicit boundaries that were not modified.",
      "items": {
        "type": "string"
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_written_to": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "privacy_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secrets_exposed",
        "customer_data_exposed",
        "raw_payloads_included",
        "redaction_applied"
      ],
      "properties": {
        "secrets_exposed": {
          "type": "boolean"
        },
        "customer_data_exposed": {
          "type": "boolean"
        },
        "raw_payloads_included": {
          "type": "boolean"
        },
        "redaction_applied": {
          "type": "boolean"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
